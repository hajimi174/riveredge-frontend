{
    "name": "riveredge-frontend",
    "version": "1.0.0",
    "description": "RiverEdge SaaS 多组织框架 - 前端 Monorepo",
    "description_en": "RiverEdge SaaS Multi-tenant Framework - Frontend Monorepo",
    "private": true,
    "scripts": {
        "dev": "cross-env VITE_HOST=0.0.0.0 vite",
        "dev:monolithic": "vite",
        "dev:saas": "vite",
        "build": "cross-env NODE_OPTIONS=--max-old-space-size=8192 vite build src && node scripts/move-dist.js",
        "build:no-move": "cross-env NODE_OPTIONS=--max-old-space-size=8192 vite build src",
        "build:16g": "cross-env NODE_OPTIONS=--max-old-space-size=16384 vite build src && node scripts/move-dist.js",
        "build:monolithic": "cross-env NODE_OPTIONS=--max-old-space-size=8192 vite build src",
        "build:saas": "cross-env NODE_OPTIONS=--max-old-space-size=8192 vite build src",
        "install:all": "npm install",
        "postinstall": "patch-package --patch-dir static/patch-package && node scripts/sync-libredwg-wasm.mjs",
        "clean": "rm -rf node_modules",
        "scan:row-action-kind": "node scripts/scan-row-action-kind.mjs"
    },
    "engines": {
        "node": ">=22.0.0",
        "npm": ">=10.0.0"
    },
